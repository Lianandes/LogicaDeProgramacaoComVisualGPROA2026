Algoritmo "menor_ou_maior"
// Disciplina   : [Lógica de Programaçăo com Visualg]
// Professor   : Jailson Carlos dos Santos
// Descriçăo   : Leia dois valores inteiros, apresente a diferença do maior
// pelo menor valor.
// Autor(a)    : Julia dos Santos Fernandes
// Data atual  : 06/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   valor1, valor2: inteiro
   resultado: inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   escreva("Digite um número: ")
   leia(valor1)
   escreva("Digite outro número: ")
   leia(valor2)
   se ( valor1 > valor2) entao
      escreval("O número ", valor1, " é maior que ", valor2)
   senao
      escreval("O número ", valor1, " é menor que ", valor2)
   fimse

Fimalgoritmo