Algoritmo "valor_do_desconto"
// Disciplina  : [Lógica de Programaçăo com Visualg]
// Professor   : Jailson Carlos dos Santos
// Descriçăo   : Leia o valor de um produto e o percentual de desconto. Calcule
// o valor do desconto e o preço final.
// Autor(a)    : Julia dos Santos Fernandes
// Data atual  : 28/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
   valor: real
   quantidade:real
   valortotal: real
   desconto: real
   valorfinal: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   escreva("Qual o preço do produto? Terá o desconto de 50%! ")
   leia(valor)
   escreva("Qual a quantidade do produto? ")
   leia(quantidade)
   valortotal <- valor * quantidade
   desconto <- valortotal * (50 / 100)
   valorfinal <- valortotal - desconto
   escreva("O valor total deu: ", "R$", valorfinal)
   

Fimalgoritmo